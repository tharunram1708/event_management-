APP_NAME="Event Management API"
ENVIRONMENT=local
DATABASE_URL=sqlite:///./event_management.db
# MySQL example:
# DATABASE_URL=mysql+pymysql://event_user:event_password@127.0.0.1:3306/event_management
JWT_SECRET_KEY=change-this-secret-before-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
LOG_LEVEL=INFO
EMAIL_FROM=no-reply@example.com
